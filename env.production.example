# 生产环境前端构建用，复制为 .env.production 后执行 npm run build
# Phase 1：AI 请求走自有后端，前端不接触 Key

VITE_APP_USE_BACKEND_AI=true
# 若 Nginx 对 www 与 api 都开了 Basic Auth，请用同源地址避免 401：前端和 API 都走 www，一次登录即可
VITE_APP_API_BASE=https://www.plc-sim.com
# 若 api 未做 Basic Auth 或单独登录，可用：VITE_APP_API_BASE=https://api.plc-sim.com
# 设为 true 则进入应用不显示调试密钥登录界面；设为 false 可恢复
VITE_APP_SKIP_LOGIN=true
VITE_APP_NAME=PLC 编程仿真器
VITE_APP_VERSION=v2.0
# 三档收费：设为 true 启用免费档/基础版 9.9/AI 周卡 19.9 控制；不设或 false 则全功能开放
VITE_APP_TIERED_PAYWALL=true
