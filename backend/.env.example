# 复制为 .env 并填写真实 Key，不要提交 .env 到 git
PORT=3000
NODE_ENV=production

# 各模型 API Key（仅服务端持有）
DEEPSEEK_API_KEY=sk-xxx
GEMINI_API_KEY=AIzaSyxxx
OPENAI_API_KEY=sk-xxx

# Phase 1：CORS 白名单，逗号分隔（生产建议仅保留正式域名）
CORS_ORIGINS=https://www.plc-sim.com,https://plc-sim.com

# Phase 2a：鉴权与计费（生产务必设置 JWT_SECRET 为随机长字符串）
JWT_SECRET=change-me-in-production
NEW_USER_BONUS_POINTS=10
AI_PRICE_POINTS=1
